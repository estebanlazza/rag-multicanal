# Copiar a .env.local y completar. NO commitear .env.local.

# --- Supabase (panel: cliente browser + server con sesión de usuario) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role: SOLO para tareas administrativas server-side puntuales.
# NO usar para el ingress /api/query (ver ADR-0002). Nunca exponer al browser.
SUPABASE_SERVICE_ROLE_KEY=

# --- Ingress /api/query (conexión Postgres con rol RLS-enforced, NO service_role) ---
# Rol app_ingress: corre con RLS activo y setea app.tenant_id por request.
SUPABASE_DB_URL=postgresql://app_ingress:CHANGE_ME@localhost:55322/postgres

# Secreto compartido / HMAC entre n8n y /api/query (n8n diferido, placeholder).
INGRESS_HMAC_SECRET=

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Extracción de documentos ---
# MarkItDown (Python) apagado por defecto: necesita worker aparte (ver docs/06-deployment.md).
MARKITDOWN_ENABLED=false

# URL pública del sitio (para SEO / canonical / Open Graph).
NEXT_PUBLIC_SITE_URL=https://ragent.beele.tech

# --- Landing pública (tenant cero / demo) ---
# Número de WhatsApp del demo, solo dígitos con código de país (sin + ni espacios).
NEXT_PUBLIC_DEMO_WHATSAPP=5491100000000
# Texto pre-cargado en el chat (atribución suave de campaña, editable por el visitante).
NEXT_PUBLIC_DEMO_WHATSAPP_TEXT=Hola! Vi su web y quiero probar el bot.
